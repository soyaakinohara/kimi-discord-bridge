# Discord Bot Token (required)
# Get it from: https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=your_discord_bot_token_here

# Workspace directory (default: ./workspace)
WORKSPACE_DIR=./workspace

# Optional: Guild ID for instant slash-command sync (leave empty for global commands)
GUILD_ID=

# Optional: Brave Search API key for web search features
# Get it from: https://api.search.brave.com/app/keys
BRAVE_API_KEY=

# Optional: Path to Kimi CLI binary (auto-detected from PATH if not set)
# KIMI_PATH=/usr/local/bin/kimi
